@startuml
!pragma layout smetana
title snowbridge Repository Architecture
skinparam shadowing false
skinparam defaultFontName Monospace
skinparam packageStyle rectangle
skinparam linetype ortho

actor "SMB clients\niPhone Files app\ntrusted devices" as smb_clients
actor "Browser clients\niPhone Safari\nlaptop browser" as browser_clients

package "Access Profiles" #F8FAFC {
  rectangle "LAN SMB\nlocal hostname / private IP" as lan_smb #FCE7F3
  rectangle "WireGuard VPN\nwireguard-public-vpn | wireguard-lan-vpn\nsplit DNS + firewall rules" as wireguard_profiles #FCE7F3
  rectangle "HTTPS profiles\nprivate-vpn | private-vpn-mtls\npublic | public-private-ip" as https_profiles #FCE7F3
}

package "snowbridge Repo" #F8FAFC {
  rectangle "README.md\ndocs/host-setup.md\ndocs/access-patterns.md\narchitecture blueprint" as repo_docs #E2E8F0
  rectangle "config/share-layout\nconfig/samba\nconfig/access\nconfig/web" as repo_config #DBEAFE
  rectangle "setup_bind_share.py\nsetup_wireguard.sh\nsetup_caddy_filebrowser.sh\nsetup_filebrowser_access.py\nexport_caddy_*_profile.py\ndebug_private_access.sh" as repo_scripts #E0F2FE
}

package "Host Runtime" #F8FAFC {
  rectangle "Samba service\ndedicated SMB user" as samba_service #DCFCE7
  rectangle "Share root\n/srv/snowbridge/share\nbind-mounted folders" as share_root #FEF3C7
  rectangle "WireGuard + dnsmasq + firewalld\nprivate routing and DNS" as private_access #DCFCE7
  rectangle "Caddy + File Browser\noptional browser access\nproxy auth or mTLS at edge" as web_stack #DCFCE7
  rectangle "Staged install artifacts\ntmp/*.mobileconfig\nCA + client profiles" as staged_profiles #FDE68A
}

package "Host-Only State" #F8FAFC {
  rectangle "External source folders\n/home/... /mnt/..." as shared_files #FEF3C7
  rectangle "Local configs / passdb / Caddy PKI\nruntime metadata / debug reports" as host_state #FDE68A
}

smb_clients --> lan_smb
smb_clients --> wireguard_profiles
browser_clients --> wireguard_profiles
browser_clients --> https_profiles

lan_smb --> samba_service
wireguard_profiles --> samba_service
wireguard_profiles --> private_access
private_access --> web_stack
https_profiles --> web_stack

repo_docs --> repo_config
repo_docs --> repo_scripts
repo_config --> repo_scripts
repo_scripts --> samba_service
repo_scripts --> share_root
repo_scripts --> private_access
repo_scripts --> web_stack
repo_scripts --> staged_profiles

samba_service --> share_root
share_root --> shared_files
private_access --> host_state
web_stack --> share_root
web_stack --> host_state
host_state --> staged_profiles

note right of https_profiles
  private-vpn-mtls terminates device certificates at Caddy.
  File Browser can stay on proxy-auth mode behind that edge.
end note

note right of share_root
  The share root lives outside git and acts as a bind-mounted
  staging tree instead of the canonical file location.
end note

note right of host_state
  Keep local configs, secrets, passdb exports, cert material,
  and debug reports out of commits.
end note
@enduml
