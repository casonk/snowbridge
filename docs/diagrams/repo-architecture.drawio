        </mxCell>
        <mxCell id="note_boundary" value="Keep SMB, VPN, and HTTPS as separate access profiles.&#10;private-vpn-mtls terminates device certificates at Caddy while File Browser can stay on proxy-auth mode behind that edge.&#10;The share root is a bind-mounted staging tree, not the canonical file location, and host-only secrets or reports stay out of commits." style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFF7ED;strokeColor=#FDBA74;fontColor=#1F2937;fontSize=16;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
