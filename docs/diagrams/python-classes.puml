  source : Path
  target_path : Path
  target_relative : PurePosixPath
}
class "GlobalSettings" as setup_bind_share.GlobalSettings {
  acl_group : str | None
  acl_user : str
  mount_dir_mode : int
  share_root : Path
  share_root_mode : int
