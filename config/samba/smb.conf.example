; snowbridge Samba baseline
; Copy this file into the host Samba configuration path and adapt the values
; for the real machine before enabling the service.
; Keep the share root as a bind-mount staging area rather than storing the
; actual files directly underneath it.

[global]
    workgroup = WORKGROUP
    server string = snowbridge personal fileshare
    netbios name = SNOWBRIDGE
    security = user
    map to guest = never
    server min protocol = SMB2_10
    load printers = no
    printing = bsd
    disable spoolss = yes

[snowbridge]
    comment = Personal cross-device fileshare
    ; Bind-mount external folders into this path with
    ; scripts/setup_bind_share.py and config/share-layout/*.ini.
    path = /srv/snowbridge/share
    browseable = yes
    read only = no
    guest ok = no
    valid users = snowbridge
    write list = snowbridge
    force user = snowbridge
    create mask = 0660
    directory mask = 2770
    inherit permissions = yes
    inherit acls = yes
    ea support = yes
    vfs objects = catia fruit streams_xattr
    fruit:metadata = stream
    fruit:model = MacSamba
