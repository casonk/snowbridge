# snowbridge File Browser and Caddy example environment
#
# Copy this file to a local-only path before use. Do not commit the host-local
# values you choose.

SNOWBRIDGE_UID=1000
SNOWBRIDGE_GID=1000
SNOWBRIDGE_SHARE_ROOT=/srv/snowbridge/share

FILEBROWSER_HTTP_PORT=8080
FILEBROWSER_DB_DIR=/var/lib/snowbridge/filebrowser/database
FILEBROWSER_CONFIG_DIR=/var/lib/snowbridge/filebrowser/config
# Override this to point both the compose service and the one-shot access
# management container at a custom File Browser fork image.
FILEBROWSER_IMAGE=docker.io/filebrowser/filebrowser:latest

# Private VPN-only example:
# Use 127.0.0.1 for host-local browsing only, or a host-reachable bind such as
# 0.0.0.0 or the WireGuard tunnel IP when phones or VPN clients should connect.
# CADDY_HTTP_BIND=0.0.0.0
# CADDY_HTTPS_BIND=0.0.0.0
# CADDYFILE_PATH=/etc/caddy/Caddyfile.private-vpn

# Private VPN-only example with client-certificate auth:
# Uses the same bind guidance as private-vpn, but Caddy also requires a client
# identity signed by the host-local mTLS client CA.
# CADDY_HTTP_BIND=0.0.0.0
# CADDY_HTTPS_BIND=0.0.0.0
# CADDYFILE_PATH=/etc/caddy/Caddyfile.private-vpn-mtls

# Public HTTPS example:
# CADDY_HTTP_BIND=0.0.0.0
# CADDY_HTTPS_BIND=0.0.0.0
# CADDYFILE_PATH=/etc/caddy/Caddyfile.public

# Public HTTPS via router/NAT to a private host IP example:
# Bind only on the host's RFC1918 address and forward 80/443 there from the
# router instead of binding on every interface.
# CADDY_HTTP_BIND=192.168.1.10
# CADDY_HTTPS_BIND=192.168.1.10
# CADDYFILE_PATH=/etc/caddy/Caddyfile.public-private-ip

CADDY_HTTP_BIND=0.0.0.0
CADDY_HTTPS_BIND=0.0.0.0
CADDYFILE_PATH=/etc/caddy/Caddyfile.private-vpn
CADDY_DATA_DIR=/var/lib/snowbridge/caddy/data
CADDY_CONFIG_DIR=/var/lib/snowbridge/caddy/config
