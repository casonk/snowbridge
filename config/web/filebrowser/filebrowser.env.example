# snowbridge File Browser and Caddy example environment
#
# Copy this file to a local-only path before use. Do not commit the host-local
# values you choose.

SNOWBRIDGE_UID=1000
SNOWBRIDGE_GID=1000
SNOWBRIDGE_SHARE_ROOT=/srv/snowbridge/share

FILEBROWSER_HTTP_PORT=8080
FILEBROWSER_DB_DIR=/var/lib/snowbridge/filebrowser/database
FILEBROWSER_CONFIG_DIR=/var/lib/snowbridge/filebrowser/config

# Private VPN-only example:
# Use 127.0.0.1 for host-local browsing only, or a host-reachable bind such as
# 0.0.0.0 or the WireGuard tunnel IP when phones or VPN clients should connect.
# CADDY_HTTP_BIND=0.0.0.0
# CADDY_HTTPS_BIND=0.0.0.0
# CADDYFILE_PATH=/etc/caddy/Caddyfile.private-vpn

# Public HTTPS example:
# CADDY_HTTP_BIND=0.0.0.0
# CADDY_HTTPS_BIND=0.0.0.0
# CADDYFILE_PATH=/etc/caddy/Caddyfile.public

CADDY_HTTP_BIND=0.0.0.0
CADDY_HTTPS_BIND=0.0.0.0
CADDYFILE_PATH=/etc/caddy/Caddyfile.private-vpn
CADDY_DATA_DIR=/var/lib/snowbridge/caddy/data
CADDY_CONFIG_DIR=/var/lib/snowbridge/caddy/config
