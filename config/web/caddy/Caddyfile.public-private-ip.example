{
	email admin@example.com
}

# snowbridge public HTTPS via router/NAT to a private host IP example
#
# Use this when the router forwards public 80/443 to the host's private
# RFC1918 address and the host should bind Caddy only on that address instead
# of 0.0.0.0. Replace the placeholders before use.

files.example.com {
	encode zstd gzip
	reverse_proxy filebrowser:8080

	# Replace the sample hash with a real bcrypt hash generated by:
	# caddy hash-password --plaintext '<strong-password>'
	basic_auth {
		webadmin $2a$14$replace_this_with_a_real_bcrypt_hash
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
	}

	log {
		output file /var/log/caddy/snowbridge-access.log
	}
}
