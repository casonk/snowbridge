{
	email admin@example.com
}

# snowbridge public HTTPS example
#
# This is higher risk than LAN/VPN-only SMB. Expose only the separate web
# service, never SMB itself. Replace the placeholders before use.

files.example.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8080

	# Replace the sample hash with a real bcrypt hash generated by:
	# caddy hash-password --plaintext '<strong-password>'
	basic_auth {
		webadmin $2a$14$replace_this_with_a_real_bcrypt_hash
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
	}

	log {
		output file /var/log/caddy/snowbridge-access.log
	}
}
