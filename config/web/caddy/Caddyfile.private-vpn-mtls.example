{
	email admin@example.com
}

# snowbridge private HTTPS + mTLS example
#
# Use this only behind a private VPN or another trusted private boundary.
# The example terminates HTTPS with Caddy's internal CA, requires a client
# certificate signed by the host-local mTLS client CA, and reverse-proxies to a
# local File Browser instance.
#
# The setup script creates the client CA at:
#   /var/lib/snowbridge/caddy/data/mtls/client-ca.crt
#   /var/lib/snowbridge/caddy/data/mtls/client-ca.key
# The export_caddy_mtls_profile.py script then issues per-device client
# identities from that CA and stages an iPhone-installable mobileconfig.

https://files.snowbridge.internal {
	tls internal {
		client_auth {
			mode require_and_verify
			trust_pool file /data/mtls/client-ca.crt
		}
	}

	encode zstd gzip
	reverse_proxy filebrowser:8080 {
		# In mTLS mode, Caddy is the authentication boundary. It injects the
		# trusted File Browser username so the app can use proxy auth and skip the
		# extra login page.
		header_up X-Snowbridge-Auth-User snowbridge
	}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
	}
}
